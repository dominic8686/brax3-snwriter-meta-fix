From e050668506aef8e2ff9ef20b2259473f8ef3e31d Mon Sep 17 00:00:00 2001
From: dominicg <dominicg@brax3.local>
Date: Tue, 21 Jul 2026 05:07:26 +0000
Subject: [PATCH] interfaces: add NVRAM HIDL 1.0 Java client

Add the MediaTek NVRAM 1.0 interface and its generated Java binding for platform clients. Keep the module Java-only because BraX3 already supplies a preferred vendor-partition native prebuilt with the same HIDL module name.

The interface matches the ODM definition and hash (24cc36ad831a00c2f48ca9fa43f51c3abe4d7174ac3e06cb5288b0f8f3c2fc00).
---
 interfaces/hardware/nvram/1.0/Android.bp      |  20 +
 interfaces/hardware/nvram/1.0/INvram.hal      |  84 ++
 .../mediatek/hardware/nvram/V1_0/INvram.java  | 765 ++++++++++++++++++
 3 files changed, 869 insertions(+)
 create mode 100644 interfaces/hardware/nvram/1.0/Android.bp
 create mode 100644 interfaces/hardware/nvram/1.0/INvram.hal
 create mode 100644 interfaces/hardware/nvram/1.0/java/vendor/mediatek/hardware/nvram/V1_0/INvram.java

diff --git a/interfaces/hardware/nvram/1.0/Android.bp b/interfaces/hardware/nvram/1.0/Android.bp
new file mode 100644
index 0000000..c534694
--- /dev/null
+++ b/interfaces/hardware/nvram/1.0/Android.bp
@@ -0,0 +1,20 @@
+//
+// SPDX-FileCopyrightText: 2016 The Android Open Source Project
+// SPDX-License-Identifier: Apache-2.0
+//
+
+// Keep this Java-only: BraX3 already supplies a preferred vendor-partition
+// prebuilt for the native vendor.mediatek.hardware.nvram@1.0 library. A full
+// hidl_interface module would try to replace that native module from system.
+// java/vendor/.../INvram.java is generated from the adjacent INvram.hal.
+java_library_static {
+    name: "vendor.mediatek.hardware.nvram-V1.0-java",
+    srcs: ["java/**/*.java"],
+    libs: [
+        "android.hidl.base-V1.0-java",
+        "hwbinder.stubs",
+    ],
+    sdk_version: "core_current",
+    installable: false,
+    visibility: ["//frameworks/base"],
+}
