From 090134007c223e7b721b7763c7c118ee21a284bd Mon Sep 17 00:00:00 2001
From: dominicg <dominicg@brax3.local>
Date: Sun, 19 Jul 2026 08:02:53 +0000
Subject: [PATCH 7/7] brax3: factory mode - port the A16 perform_apex_config
 fix from META

Port of the verified snWriter fix (45921b5) to factory_init.rc, which has
the identical A13-derived latent bugs:
- dead exec of /system/bin/bootstrap/linkerconfig (binary does not exist
  on A15/16) replaced with the stub-write pattern from meta_init.system.rc
- perform_apex_config (+ restorecon of /bootstrap-apex/apex-info-list.xml)
  added right after exec_start apexd-bootstrap, restoring the A16 contract
  so the apex-info manifest gets the apex_info_file label and HALs can
  register in factory mode
- stale comment on the inline vendor.boot-default service corrected
  (perform_apex_config runs at early-init now, not post-fs-data only;
  inline definition kept as belt-and-suspenders)

Untested in factory mode (no factory-mode test cycle yet); mirrors the
proven META state exactly.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
Change-Id: I8285d5ea543a91628a44c036ea63eacdb565f931
---
 init/factory_init.rc | 34 +++++++++++++++++++++++++---------
 1 file changed, 25 insertions(+), 9 deletions(-)

diff --git a/init/factory_init.rc b/init/factory_init.rc
index eb259b3..7b7cf4c 100644
--- a/init/factory_init.rc
+++ b/init/factory_init.rc
@@ -15,11 +15,11 @@ import /system_ext/etc/init/hw/init.aee.rc
 import /vendor/etc/init/vendor.mediatek.hardware.mtkpower@1.0-service.rc
 # The HIDL boot@1.2 rc files these imports pointed at do not exist in this
 # build: the boot-control HAL ships as the vendor APEX com.android.hardware.boot
-# and its rc is only parsed at perform_apex_config (post-fs-data) -- a stage
-# factory mode never reaches, because mount_all --late (see `on late-fs`) blocks
-# in vold waiting on IBootControl to resolve the A/B slot for super's logical
-# partitions. init skips missing imports silently, so class_start early_hal was
-# starting every early HAL except the one vold needs. Define the service here.
+# and its rc is parsed by perform_apex_config (now run in `on early-init` right
+# after apexd-bootstrap, per the A16 contract). Keep this inline definition as
+# belt-and-suspenders (duplicate service definitions are ignored by init):
+# without the HAL, mount_all --late blocks in vold waiting on IBootControl to
+# resolve the A/B slot for super's logical partitions.
 service vendor.boot-default /apex/com.android.hardware.boot/bin/hw/android.hardware.boot-service.default
     interface aidl android.hardware.boot.IBootControl/default
     class early_hal
@@ -62,11 +62,15 @@ on early-init
     mkdir /linkerconfig/bootstrap 0755
     mkdir /linkerconfig/default 0755
 
-    # Generate ld.config.txt for early executed processes
-    exec -- /system/bin/bootstrap/linkerconfig --target /linkerconfig/bootstrap
-
+    # Seed a stub ld.config.txt for early-executed processes. The A13-era
+    # `exec /system/bin/bootstrap/linkerconfig` was inherited from the BSP but
+    # that binary does NOT exist on A15/16 (linkerconfig moved into the
+    # com.android.runtime APEX), so the exec failed silently and no config was
+    # ever created. Same fix as meta_init.system.rc; matches iode's own
+    # normal-boot init.rc (A15/16).
+    write /linkerconfig/bootstrap/ld.config.txt \#
+    write /linkerconfig/default/ld.config.txt \#
     chmod 644 /linkerconfig/bootstrap/ld.config.txt
-    copy /linkerconfig/bootstrap/ld.config.txt /linkerconfig/default/ld.config.txt
     chmod 644 /linkerconfig/default/ld.config.txt
 
     # Mount bootstrap linker configuration as current
@@ -80,6 +84,18 @@ on early-init
     # the libraries are available to the processes started after this statement.
     exec_start apexd-bootstrap
 
+    # A16 CONTRACT FIX (ported from meta_init.system.rc, where it fixed the
+    # snWriter backup and is VERIFIED green-PASS): normal A16 init.rc runs
+    # perform_apex_config immediately after apexd-bootstrap. A16 apexd no longer
+    # restorecons the apex-info-list.xml it writes; without this step the
+    # manifest keeps the tmpfs label apex_mnt_dir -> servicemanager can't read
+    # it -> NULL VINTF -> no HAL can register in factory mode. Also parses
+    # APEX-shipped init .rc files and generates the linker config natively.
+    perform_apex_config
+    # Belt-and-suspenders: apply the file_contexts label (sepolicy commit
+    # b2cffb30d) to the bootstrap-view path directly as well.
+    restorecon /bootstrap-apex/apex-info-list.xml
+
     # Generate linker config based on apex mounted in bootstrap namespace
     update_linker_config
 
-- 
