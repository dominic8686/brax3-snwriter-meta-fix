diff --git a/init/brax-metadiag.sh b/init/brax-metadiag.sh
new file mode 100644
index 0000000..02eebdb
--- /dev/null
+++ b/init/brax-metadiag.sh
@@ -0,0 +1,47 @@
+#!/system/bin/sh
+# TEMP META diagnostic - NOT for commit. Captures WHY snWriter's final backup
+# (REQ_BackupNvram2BinRegion / SP_META_SetCleanBootFlag_r) times out (15s) even
+# though META is healthy (IMEI + modem NVRAM work). Runs as u:r:su:s0.
+#
+# Key addition: every 2s it dumps the KERNEL STACK (/proc/<pid>/stack), state and
+# wchan of each backup actor, so during the 15s hang we can see exactly what the
+# handler is blocked on (a syscall / mutex / modem-CCCI wait / socket / block I/O).
+# Also keeps dmesg/logcat/avc and a full ps of D-state + nvram/meta/ccci procs.
+D=/mnt/vendor/nvdata
+auditctl -r 0 -b 16384 2>/dev/null
+: > $D/bx-stacks.txt
+: > $D/bx-ps.txt
+getprop > $D/bx-props.txt 2>&1
+getenforce > $D/bx-enforce.txt 2>&1
+
+ACTORS="nvram_daemon meta_tst mtk_hal_nvramagent nvram_agent ccci_mdinit ccci_rpcd atcid md_ctrl"
+
+i=0
+while [ $i -lt 90 ]; do
+    auditctl -r 0 2>/dev/null
+    UP=$(cat /proc/uptime 2>/dev/null | cut -d. -f1)
+    {
+        echo "======== loop $i  up=${UP}s  $(date) ========"
+        for a in $ACTORS; do
+            for pid in $(pidof "$a" 2>/dev/null); do
+                STATE=$(awk '{print $3}' /proc/$pid/stat 2>/dev/null)
+                WCHAN=$(cat /proc/$pid/wchan 2>/dev/null)
+                echo "--- $a pid=$pid state=$STATE wchan=$WCHAN ---"
+                cat /proc/$pid/stack 2>/dev/null
+                echo "  syscall: $(cat /proc/$pid/syscall 2>/dev/null)"
+            done
+        done
+    } >> $D/bx-stacks.txt 2>&1
+
+    ps -A -o PID,PPID,STAT,WCHAN:24,NAME 2>/dev/null | grep -iE "STAT|nvram|meta|ccci|md_|atci| D " >> $D/bx-ps.txt 2>&1
+    echo "---- loop $i up=${UP}s ----" >> $D/bx-ps.txt 2>&1
+
+    dmesg 2>/dev/null | grep -i "avc:" > $D/.bx-avc.tmp 2>&1; mv $D/.bx-avc.tmp $D/bx-avc.txt 2>/dev/null
+    if [ $((i % 3)) -eq 0 ]; then
+        dmesg > $D/.d.tmp 2>&1; mv $D/.d.tmp $D/bx-dmesg2.txt 2>/dev/null
+        logcat -b all -d > $D/.l.tmp 2>&1; mv $D/.l.tmp $D/bx-logcat2.txt 2>/dev/null
+    fi
+    sync
+    i=$((i+1))
+    sleep 2
+done
diff --git a/init/factory_init.rc b/init/factory_init.rc
index 92ec323..eb259b3 100644
--- a/init/factory_init.rc
+++ b/init/factory_init.rc
@@ -13,8 +13,18 @@ import /vendor/etc/init/microtrust.rc
 import /vendor/etc/init/hw/init.aee.rc
 import /system_ext/etc/init/hw/init.aee.rc
 import /vendor/etc/init/vendor.mediatek.hardware.mtkpower@1.0-service.rc
-import /vendor/etc/init/android.hardware.boot@1.2-service.rc
-import /vendor/etc/init/android.hardware.boot@1.2-service-lazy.rc
+# The HIDL boot@1.2 rc files these imports pointed at do not exist in this
+# build: the boot-control HAL ships as the vendor APEX com.android.hardware.boot
+# and its rc is only parsed at perform_apex_config (post-fs-data) -- a stage
+# factory mode never reaches, because mount_all --late (see `on late-fs`) blocks
+# in vold waiting on IBootControl to resolve the A/B slot for super's logical
+# partitions. init skips missing imports silently, so class_start early_hal was
+# starting every early HAL except the one vold needs. Define the service here.
+service vendor.boot-default /apex/com.android.hardware.boot/bin/hw/android.hardware.boot-service.default
+    interface aidl android.hardware.boot.IBootControl/default
+    class early_hal
+    user root
+    group root
 import /vendor/etc/init/vendor.mediatek.hardware.thp@1.0-service.rc
 import /vendor/etc/init/android.hardware.health-service.example.rc
 
diff --git a/init/meta_init.rc b/init/meta_init.rc
index d5d23c8..c56dc5d 100644
--- a/init/meta_init.rc
+++ b/init/meta_init.rc
@@ -11,8 +11,17 @@ import /vendor/etc/init/trustonic.rc
 import /vendor/etc/init/hw/meta_init.connectivity.rc
 import /vendor/etc/init/hw/meta_init.project.rc
 import /vendor/etc/init/microtrust.rc
-import /vendor/etc/init/android.hardware.boot@1.2-service.rc
-import /vendor/etc/init/android.hardware.boot@1.2-service-lazy.rc
+# The HIDL boot@1.2 rc files these imports pointed at do not exist in this
+# build: the boot-control HAL ships as the vendor APEX com.android.hardware.boot
+# and its rc is only parsed at perform_apex_config (post-fs-data) -- a stage
+# META never reaches, because mount_all --late deadlocks waiting on
+# IBootControl. Define the service here so class_start early_hal (late-fs)
+# can start it, matching how the MTK BSP handles META (bootctl in early_hal).
+service vendor.boot-default /apex/com.android.hardware.boot/bin/hw/android.hardware.boot-service.default
+    interface aidl android.hardware.boot.IBootControl/default
+    class early_hal
+    user root
+    group root
 import /vendor/etc/init/android.hardware.health-service.example.rc
 import /vendor/etc/init/android.hardware.health-service.mediatek.rc
 
@@ -199,10 +208,13 @@ on post-fs
     mkdir /mnt/vendor/nvdata/media 0771 media audio
     restorecon_recursive /mnt/vendor/nvdata
 
+    # TEMP DIAG - not for commit. Started at post-fs (a separate process) so it
+    # still completes even if a later init stage stalls.
+    start brax_metadiag
 #INTERNAL_END
 
 on late-fs
-    start keystore2
+    # keystore2 NOT started (Option A deadlocks on A15/16 -- see meta_init.system.rc).
     start vendor.keymaster-3-0
     start vendor.keymaster-3-0-trustonic
     start vendor.keymaster-4-0
@@ -218,7 +230,14 @@ on late-fs
     class_start early_hal
     start keymaster_attestation-1-1
     exec_start wait_for_keymaster
-    mount_all --late
+    # APEXFIX flow (best working state): raw ext4 /data mount, no keystore2/vold.
+    # mount_all --late would deadlock (keystore2 can't link -- see meta_init.system.rc).
+    # META is healthy this way: IMEI + modem NVRAM work; only the SetCleanBootFlag
+    # backup times out (needs TEE/RPMB which needs keystore2/TEE-daemon that can't
+    # link). Raw mount fails harmlessly on encrypted userdata; META works without /data.
+    mount ext4 /dev/block/by-name/userdata /data noatime nosuid nodev noauto_da_alloc discard wait
+    chmod 0771 /data
+    chown system system /data
 
 on post-fs-data
     write /proc/bootprof "INIT:post-fs-data"
@@ -324,6 +343,16 @@ service meta_tst /vendor/bin/meta_tst
     group radio system wifi audio bluetooth media gps
     socket meta-atci stream 660 radio system
 
+# TEMP DIAG - not for commit. seclabel MUST be su:s0, not shell:s0: under
+# ENFORCING, shell is denied write to nvdata_file, so a shell-labelled dump
+# would silently produce nothing.
+service brax_metadiag /system/bin/sh /vendor/bin/brax-metadiag.sh
+    user root
+    group root system
+    disabled
+    oneshot
+    seclabel u:r:su:s0
+
 service factory_no_image /vendor/bin/factory
     user root
     group radio system wifi media gps audio bluetooth wakelock nfc
diff --git a/init/meta_init.system.rc b/init/meta_init.system.rc
index 3db5879..4b10e31 100644
--- a/init/meta_init.system.rc
+++ b/init/meta_init.system.rc
@@ -29,7 +29,14 @@ import /system/etc/init/storagemanagerd.rc
 import /system_ext/etc/init/mobile_log_d.rc
 import /system/etc/init/android.system.suspend-service.rc
 import /system/etc/init/wait_for_keymaster.rc
-import /system/etc/init/keystore2.rc
+# keystore2 NOT started in META. Option A (keystore2 + mount_all --late) DEADLOCKS
+# on A15/16: keystore2 crashes on link ("libandroidicu.so not found ... in namespace
+# default") because the full /linkerconfig (routing the com.android.i18n apex libs)
+# is only generated by perform_apex_config at post-fs-data -- AFTER late-fs -- and
+# mount_all --late's wait-for-keystore2 deadlock prevents ever reaching post-fs-data.
+# Circular; an A13->A15/16 regression (works on the A13 BSP). See worklog 2026-07-18
+# session 2. Stay on the healthy APEXFIX flow (relabel + no keystore2 + raw /data).
+#import /system/etc/init/keystore2.rc
 import /system_ext/etc/init/emdlogger.rc
 
 #end
@@ -52,10 +59,16 @@ on early-init
     mkdir /linkerconfig/bootstrap 0755
     mkdir /linkerconfig/default 0755
 
-    # Generate ld.config.txt for early executed processes
-    exec -- /system/bin/bootstrap/linkerconfig --target /linkerconfig/bootstrap
+    # Seed a stub ld.config.txt for early-executed processes. The A13-era line
+    # `exec /system/bin/bootstrap/linkerconfig --target ...` was inherited from the
+    # BSP but that binary does NOT exist on A15/16 (linkerconfig moved into
+    # com.android.runtime APEX), so the exec failed, the bootstrap stub was never
+    # created, and update_linker_config never produced /linkerconfig/ld.config.txt
+    # -> keystore2 could not link -> mount_all --late deadlocked -> META backup
+    # (SetCleanBootFlag) hung. This matches iode's OWN normal-boot init.rc (A15/16).
+    write /linkerconfig/bootstrap/ld.config.txt \#
+    write /linkerconfig/default/ld.config.txt \#
     chmod 644 /linkerconfig/bootstrap/ld.config.txt
-    copy /linkerconfig/bootstrap/ld.config.txt /linkerconfig/default/ld.config.txt
     chmod 644 /linkerconfig/default/ld.config.txt
 
     # Mount bootstrap linker configuration as current
