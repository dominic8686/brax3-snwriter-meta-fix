From 3fe1dcc7af24dc1131a08ffe6bc066fec2b6ab05 Mon Sep 17 00:00:00 2001
From: dominicg <dominicg@brax3.local>
Date: Tue, 21 Jul 2026 05:07:13 +0000
Subject: [PATCH 08/10] brax3: add PriFactoryTest factory hardware test app

Ship the ODM factory test suite in the production image through the proprietary extraction workflow. The generated android_app_import re-signs the privileged APK with the platform certificate so its android.uid.system request is accepted.

Install the corresponding privileged-permission allowlist on system. Runtime compatibility with the ODM NVRAM API is supplied by the companion frameworks/base and hardware/mediatek changes.

Change-Id: I2b1087a719b7232a372b1d2c5371231eb818e0b2
---
 ...rivapp-permissions-com.pri.factorytest.xml | 26 +++++++++++++++++++
 device.mk                                     |  9 +++++++
 proprietary-files.txt                         |  4 +++
 3 files changed, 39 insertions(+)
 create mode 100644 configs/permissions/privapp-permissions-com.pri.factorytest.xml

diff --git a/configs/permissions/privapp-permissions-com.pri.factorytest.xml b/configs/permissions/privapp-permissions-com.pri.factorytest.xml
new file mode 100644
index 0000000..4964643
--- /dev/null
+++ b/configs/permissions/privapp-permissions-com.pri.factorytest.xml
@@ -0,0 +1,26 @@
+<?xml version="1.0" encoding="utf-8"?>
+<!-- Privileged-permission allowlist for the ODM factory hardware-test app. -->
+<permissions>
+    <privapp-permissions package="com.pri.factorytest">
+        <permission name="android.permission.ACCESS_KEYGUARD_SECURE_STORAGE"/>
+        <permission name="android.permission.BIND_DEVICE_ADMIN"/>
+        <permission name="android.permission.CALL_PRIVILEGED"/>
+        <permission name="android.permission.CHANGE_CONFIGURATION"/>
+        <permission name="android.permission.CONTROL_INCALL_EXPERIENCE"/>
+        <permission name="android.permission.DEVICE_POWER"/>
+        <permission name="android.permission.DISABLE_KEYGUARD"/>
+        <permission name="android.permission.DUMP"/>
+        <permission name="android.permission.FORCE_STOP_PACKAGES"/>
+        <permission name="android.permission.INTERNAL_SYSTEM_WINDOW"/>
+        <permission name="android.permission.MANAGE_FINGERPRINT"/>
+        <permission name="android.permission.MASTER_CLEAR"/>
+        <permission name="android.permission.MODIFY_AUDIO_SETTINGS"/>
+        <permission name="android.permission.MOUNT_UNMOUNT_FILESYSTEMS"/>
+        <permission name="android.permission.READ_PHONE_STATE"/>
+        <permission name="android.permission.TRANSMIT_IR"/>
+        <permission name="android.permission.WRITE_MEDIA_STORAGE"/>
+        <permission name="android.permission.WRITE_OWNER_DATA"/>
+        <permission name="android.permission.WRITE_SECURE_SETTINGS"/>
+        <permission name="android.permission.WRITE_SETTINGS"/>
+    </privapp-permissions>
+</permissions>
diff --git a/device.mk b/device.mk
index bb94742..49e4d3d 100644
--- a/device.mk
+++ b/device.mk
@@ -1,6 +1,15 @@
 $(call inherit-product, $(SRC_TARGET_DIR)/product/virtual_ab_ota/launch_with_vendor_ramdisk.mk)
 $(call inherit-product, $(SRC_TARGET_DIR)/product/generic_ramdisk.mk)
 
+# ODM factory hardware-test app. The APK is extracted through
+# proprietary-files.txt and re-signed with the iodé platform certificate by
+# the generated android_app_import module, which is required for uid 1000.
+PRODUCT_PACKAGES += \
+    PriFactoryTest
+
+PRODUCT_COPY_FILES += \
+    $(LOCAL_PATH)/configs/permissions/privapp-permissions-com.pri.factorytest.xml:$(TARGET_COPY_OUT_SYSTEM)/etc/permissions/privapp-permissions-com.pri.factorytest.xml
+
 # A/B
 PRODUCT_PACKAGES += \
     com.android.hardware.boot \
diff --git a/proprietary-files.txt b/proprietary-files.txt
index 143f3b2..061c223 100644
--- a/proprietary-files.txt
+++ b/proprietary-files.txt
@@ -1266,6 +1266,10 @@ vendor/lib64/libwifical.so
 # system_ext/bin/loghidlsysservice
 # system_ext/etc/init/loghidlsysservice.rc
 
+# PriFactoryTest
+system/priv-app/PriFactoryTest/PriFactoryTest.apk
+
+# EngineerMode
 system_ext/app/EngineerMode/EngineerMode.apk
 # system_ext/lib/libem_support_jni.so
 system_ext/lib64/libem_support_jni.so
-- 
2.53.0

