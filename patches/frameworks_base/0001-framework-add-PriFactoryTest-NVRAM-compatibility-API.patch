From 25af55eb9197c1341a62c9e726ab5b7f774cf160 Mon Sep 17 00:00:00 2001
From: dominicg <dominicg@brax3.local>
Date: Tue, 21 Jul 2026 05:07:27 +0000
Subject: [PATCH 1/2] framework: add PriFactoryTest NVRAM compatibility API

Provide the com.pri.utils.NvramUtils ABI expected by the ODM factory-test APK and link the MediaTek NVRAM HIDL Java client into framework-internal-utils.

Keep all reads and writes behind the existing NVRAM HAL, restrict requests to the factory/user/product-info records used by the APK, validate offsets and buffer lengths, and preserve the ODM prefix-read behavior.
---
 Android.bp                              |   1 +
 core/java/com/pri/utils/NvramUtils.java | 240 ++++++++++++++++++++++++
 2 files changed, 241 insertions(+)
 create mode 100644 core/java/com/pri/utils/NvramUtils.java

diff --git a/Android.bp b/Android.bp
index 939c2417a627..e29617f9342e 100644
--- a/Android.bp
+++ b/Android.bp
@@ -256,6 +256,7 @@ java_library {
         "com.android.sysprop.localization",
         "PlatformProperties",
         "SurfaceFlingerProperties",
+        "vendor.mediatek.hardware.nvram-V1.0-java",
     ],
     sdk_version: "core_platform",
     installable: false,
diff --git a/core/java/com/pri/utils/NvramUtils.java b/core/java/com/pri/utils/NvramUtils.java
new file mode 100644
index 000000000000..4a20c3a74ba5
--- /dev/null
+++ b/core/java/com/pri/utils/NvramUtils.java
@@ -0,0 +1,240 @@
